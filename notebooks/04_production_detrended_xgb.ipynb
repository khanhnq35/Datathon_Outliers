   "source": [
    "# Datathon 2026 - Sales Forecasting (Optimal + Post-Tet Fix)\n",
    "**Mục tiêu:** Xử lý độ lệch dự báo giai đoạn Tháng 2-3/2022 bằng cách mở rộng đặc trưng Tết và hậu Tết."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 1. Libraries & Config"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import plotly.graph_objects as go\n",
    "from xgboost import XGBRegressor\n",
    "from sklearn.metrics import mean_absolute_error\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "TRAIN_PATH = '../Data/sales.csv'\n",
    "SUBMISSION_SAMPLE_PATH = '../Data/sample_submission.csv'\n",
    "OUTPUT_PATH = '../submission_v4_production_optimal.csv'\n",
    "RANDOM_SEED = 42"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 2. Feature Engineering (Enhanced Tet Features)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "TET_DATES = pd.to_datetime([\n",
    "    '2012-01-23', '2013-02-10', '2014-01-31', '2015-02-19', '2016-02-08',\n",
    "    '2017-01-28', '2018-02-16', '2019-02-05', '2020-01-25', '2021-02-12',\n",
    "    '2022-02-01', '2023-01-22', '2024-02-10'\n",
    "])\n",
    "\n",
    "def create_features(df):\n",
    "    out = df.copy()\n",
    "    out['month'] = out['Date'].dt.month\n",
    "    out['day'] = out['Date'].dt.day\n",
    "    out['dayofweek'] = out['Date'].dt.dayofweek\n",
    "    out['is_weekend'] = out['dayofweek'].isin([5, 6]).astype(int)\n",
    "    \n",
    "    out['is_holiday'] = 0\n",
    "    for m, d in [(1,1), (4,30), (5,1), (9,2), (12,25)]: \n",
    "        out.loc[(out['month']==m) & (out['day']==d), 'is_holiday'] = 1\n",
    "        \n",
    "    # Mở rộng vùng ảnh hưởng của Tết: -21 ngày đến +30 ngày\n",
    "    out['days_to_tet'] = 999\n",
    "    for tet in TET_DATES:\n",
    "        diff = (out['Date'] - tet).dt.days\n",
    "        mask = (diff >= -21) & (diff <= 30)\n",
    "        out.loc[mask, 'days_to_tet'] = diff[mask]\n",
    "        \n",
    "    # Thêm đặc trưng phân loại giai đoạn Tết\n",
    "    out['is_pre_tet'] = ((out['days_to_tet'] >= -21) & (out['days_to_tet'] < 0)).astype(int)\n",
    "    out['is_tet_week'] = ((out['days_to_tet'] >= 0) & (out['days_to_tet'] <= 7)).astype(int)\n",
    "    out['is_post_tet'] = ((out['days_to_tet'] > 7) & (out['days_to_tet'] <= 30)).astype(int)\n",
    "    \n",
    "    return out"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 3. Modeling & Backtest\n",
    "Kiểm tra xem việc mở rộng đặc trưng Tết có giúp khớp hơn ở giai đoạn Tháng 2-3/2022 không."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df_train = pd.read_csv(TRAIN_PATH, parse_dates=['Date']).sort_values('Date').reset_index(drop=True)\n",
    "df_sample = pd.read_csv(SUBMISSION_SAMPLE_PATH, parse_dates=['Date']).sort_values('Date').reset_index(drop=True)\n",
    "\n",
    "XGB_PARAMS = {\n",
    "    'n_estimators': 1334, 'learning_rate': 0.02017, 'max_depth': 5,\n",
    "    'subsample': 0.655, 'colsample_bytree': 0.732, 'min_child_weight': 10,\n",
    "    'random_state': 42, 'objective': 'reg:squarederror', 'tree_method': 'hist'\n",
    "}\n",
    "\n",
    "def fit_predict(train_df, future_dates, target_col):\n",
    "    tr = train_df.copy()\n",
    "    tr['year'] = tr['Date'].dt.year\n",
    "    annual_mean = tr.groupby('year')[target_col].mean()\n",
    "    tr['norm_target'] = tr[target_col] / tr['year'].map(annual_mean)\n",
    "    \n",
    "    x_train = create_features(tr)\n",
    "    x_future = create_features(pd.DataFrame({'Date': pd.to_datetime(future_dates)}))\n",
    "    f_cols = ['month', 'day', 'dayofweek', 'is_weekend', 'is_holiday', 'days_to_tet', 'is_pre_tet', 'is_tet_week', 'is_post_tet']\n",
    "    \n",
    "    model = XGBRegressor(**XGB_PARAMS)\n",
    "    model.fit(x_train[f_cols], tr['norm_target'])\n",
    "    \n",
    "    growth = annual_mean.pct_change().dropna().mean() + 1\n",
    "    base_mean = float(annual_mean.iloc[-1])\n",
    "    yearly_scale = base_mean * (growth ** (x_future['Date'].dt.year - int(annual_mean.index[-1])))\n",
    "    return np.clip(model.predict(x_future[f_cols]) * yearly_scale, 0, None)\n",
    "\n",
    "# Backtest\n",
    "split_date = df_train['Date'].max() - pd.Timedelta(days=548)\n",
    "tr_split = df_train[df_train['Date'] <= split_date]\n",
    "val_split = df_train[df_train['Date'] > split_date]\n",
    "rev_pred = fit_predict(tr_split, val_split['Date'], 'Revenue')\n",
    "\n",
    "print(f\"Revenue MAE: {mean_absolute_error(val_split['Revenue'], rev_pred):,.0f}\")\n",
    "\n",
    "fig = go.Figure()\n",
    "fig.add_trace(go.Scatter(x=val_split['Date'], y=val_split['Revenue'], name='Thực tế', opacity=0.4))\n",
    "fig.add_trace(go.Scatter(x=val_split['Date'], y=rev_pred, name='Dự báo (Fix Post-Tet)', line=dict(color='red')))\n",
    "fig.update_layout(title='Backtest 2022: Soi chi tiết Tháng 2-3', hovermode='x unified', xaxis=dict(rangeslider=dict(visible=True)))\n",
    "fig.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 4. Final Submission"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "rev_final = fit_predict(df_train, df_sample['Date'], 'Revenue')\n",
    "cogs_final = fit_predict(df_train, df_sample['Date'], 'COGS')\n",
    "submission = df_sample.copy()\n",
    "submission['Revenue'] = rev_final; submission['COGS'] = cogs_final\n",
    "submission['Date'] = submission['Date'].dt.strftime('%Y-%m-%d')\n",
    "submission.to_csv(OUTPUT_PATH, index=False)\n",
    "print(f\"[+] File submission TỐI ƯU (Đã fix Tết) đã lưu tại: {OUTPUT_PATH}\")"
   ]
  }
 ],
